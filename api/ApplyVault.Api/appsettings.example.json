{
  "ConnectionStrings": {
    "ApplyVault": "Server=(localdb)\\mssqllocaldb;Database=ApplyVault;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True",
    "Redis": ""
  },
  "Database": {
    "MigrateAtStartup": true
  },
  "GoogleAi": {
    "Enabled": true,
    "Model": "gemini-2.5-flash",
    "ApiKey": "",
    "TimeoutSeconds": 30
  },
  "ScrapeResultEnrichment": {
    "Enabled": true,
    "FailOnAiError": false
  },
  "Supabase": {
    "Url": "https://your-project.supabase.co",
    "Audience": "authenticated"
  },
  "CalendarIntegration": {
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/calendar/callback",
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5173/api/calendar-connections/google/callback"
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "RedirectUri": "http://localhost:5173/api/calendar-connections/microsoft/callback"
    }
  },
  "GitHubIntegration": {
    "Enabled": false,
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/github/callback",
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5173/api/github-connections/github/callback",
    "Scopes": "read:user repo"
  },
  "GitHubProjectAi": {},
  "CvImportAi": {},
  "CvUpdateAi": {},
  "CvSuggestionsAi": {},
  "CvExportAi": {},
  "MailIntegration": {
    "Enabled": false,
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/mail/callback",
    "PollIntervalSeconds": 60,
    "InitialLookbackHours": 168,
    "MaxMessagesPerSync": 20,
    "Gmail": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5173/api/mail-connections/gmail/callback"
    }
  },
  "EuresIntegration": {
    "BaseUrl": "https://europa.eu/eures/api",
    "DefaultLocationCode": "dk",
    "MaxResultsPerPage": 50,
    "TimeoutSeconds": 30
  },
  "CvHtmlExport": {
    "EnableHtmlTemplates": false,
    "TemplatesSubfolder": "cv-export-templates",
    "MaxConcurrentExports": 2
  },
  "CvDocumentStorage": {
    "Provider": "Local",
    "MaxFileSizeBytes": 5242880,
    "Local": {
      "RootPath": "App_Data/cv-documents"
    },
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "cv-documents"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "RateLimiting": {
    "Enabled": false,
    "GlobalApi": {
      "PermitLimit": 200,
      "WindowSeconds": 60
    },
    "ScrapeIngest": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "EuresSearch": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    },
    "OAuthCallback": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "Testing": {
    "UseInMemoryDatabase": false,
    "InMemoryDatabaseName": "ApplyVaultTests"
  }
}
