{
  "ConnectionStrings": {
    "ApplyVault": "Server=.;Database=ApplyVault;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
  },
  "Database": {
    "MigrateAtStartup": true
  },
  "GoogleAi": {
    "Enabled": false,
    "Model": "gemini-2.5-flash",
    "ApiKey": "",
    "TimeoutSeconds": 30
  },
  "ScrapeResultEnrichment": {
    "Enabled": false,
    "FailOnAiError": false
  },
  "Supabase": {
    "Url": "",
    "Audience": "authenticated"
  },
  "CalendarIntegration": {
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/calendar/callback",
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5173/api/calendar-connections/google/callback"
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "RedirectUri": "http://localhost:5173/api/calendar-connections/microsoft/callback"
    }
  },
  "GitHubIntegration": {
    "Enabled": false,
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/github/callback",
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5173/api/github-connections/github/callback",
    "Scopes": "read:user repo"
  },
  "GitHubProjectAi": {},
  "MailIntegration": {
    "Enabled": false,
    "PostConnectRedirectUrl": "http://localhost:4200/integrations/mail/callback",
    "PollIntervalSeconds": 60,
    "InitialLookbackHours": 168,
    "MaxMessagesPerSync": 20,
    "Gmail": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5173/api/mail-connections/gmail/callback"
    }
  },
  "EuresIntegration": {
    "BaseUrl": "https://europa.eu/eures/api",
    "DefaultLocationCode": "dk",
    "MaxResultsPerPage": 50,
    "TimeoutSeconds": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "Enabled": false,
    "GlobalApi": {
      "PermitLimit": 200,
      "WindowSeconds": 60
    },
    "ScrapeIngest": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "EuresSearch": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    },
    "OAuthCallback": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
