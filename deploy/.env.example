# Copy to deploy/.env on the host. Never commit deploy/.env.

# Public API hostname (used by Caddy for HTTPS). Example: api.applyvault.example
API_DOMAIN=api.example.com

# Dashboard origin — must match Cors__AllowedOrigins__0 and OAuth post-connect URLs
APP_DOMAIN=app.example.com

# Required — see plans/production-readiness/ENV.md
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__ApplyVault=Server=tcp:your-server.database.windows.net,1433;Database=ApplyVault;User ID=...;Password=...;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Required when running more than one API replica (EURES cache + Gmail sync lock)
# ConnectionStrings__Redis=redis:6379,password=your-redis-password
Supabase__Url=https://your-project.supabase.co
Cors__AllowedOrigins__0=https://app.example.com

# Option B migrations (Production default): run deploy/scripts/migrate.sh before deploy
Database__MigrateAtStartup=false

# Rate limiting (enabled in Production/Staging appsettings; override limits without redeploy)
# RateLimiting__Enabled=true
# RateLimiting__ScrapeIngest__PermitLimit=30
# RateLimiting__EuresSearch__PermitLimit=20
# RateLimiting__OAuthCallback__PermitLimit=10
# RateLimiting__GlobalApi__PermitLimit=200

# Optional integrations — set when enabled (see plans/production-readiness/OAUTH.md)
# GoogleAi__Enabled=false
# GoogleAi__ApiKey=
# CalendarIntegration__PostConnectRedirectUrl=https://app.example.com/integrations/calendar/callback
# CalendarIntegration__Google__ClientId=
# CalendarIntegration__Google__ClientSecret=
# CalendarIntegration__Google__RedirectUri=https://api.example.com/api/calendar-connections/google/callback
# CalendarIntegration__Microsoft__ClientId=
# CalendarIntegration__Microsoft__ClientSecret=
# CalendarIntegration__Microsoft__TenantId=common
# CalendarIntegration__Microsoft__RedirectUri=https://api.example.com/api/calendar-connections/microsoft/callback
# MailIntegration__Enabled=false
# MailIntegration__PostConnectRedirectUrl=https://app.example.com/integrations/mail/callback
# MailIntegration__Gmail__ClientId=
# MailIntegration__Gmail__ClientSecret=
# MailIntegration__Gmail__RedirectUri=https://api.example.com/api/mail-connections/gmail/callback
