{
  "name": "applyvault-extension",
  "version": "0.1.0",
  "description": "Chrome MV3 extension for capturing job listing details and saving them to the ApplyVault API.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:staging": "node scripts/build.mjs --configuration staging",
    "build:production": "node scripts/build.mjs --configuration production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "node scripts/build.mjs --watch"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "scraper",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/jsdom": "^21.1.7",
    "esbuild": "^0.27.4",
    "jsdom": "^24.1.3",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1"
  }
}
